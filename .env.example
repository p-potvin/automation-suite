# automation-suite — example environment file
# Copy this to .env and fill in your actual values.
# The .env file is gitignored and will not be committed.

# ─── Concurrent Sessions ─────────────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=1

# ─── MultiLogin ───────────────────────────────────────────────────────────────
MULTILOGIN_API_URL=https://api.multilogin.com/v1
MULTILOGIN_API_KEY=YOUR_MULTILogin_API_KEY
MULTILOGIN_PROFILE_NAME=automation_profile_01
MULTILOGIN_OS_TYPE=Windows 10
MULTILOGIN_BROWSER=Chrome

# ─── Stealth Browser ──────────────────────────────────────────────────────────
# Provider: patchright | kameleo | multilogin
STEALTH_PROVIDER=patchright
STEALTH_HEADLESS=false

# ─── Kameleo (if STEALTH_PROVIDER=kameleo) ────────────────────────────────────
KAMELEO_API_URL=http://localhost:5050
KAMELEO_API_TOKEN=
KAMELEO_PROFILE_ID=

# ─── Tor Proxy Rotation ───────────────────────────────────────────────────────
# Tor is used by default with per-session SOCKS ports and NEWNYM rotation.
TOR_ENABLED=1
TOR_CONTROL_HOST=127.0.0.1
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=mypassword
TOR_SOCKS_START_PORT=20000
TOR_SOCKS_PORT_COUNT=50

# ─── IPoasis (fallback when Tor is disabled) ──────────────────────────────────
IPOASIS_API_KEY=YOUR_IPOASIS_API_KEY
IPOASIS_COUNTRY=US

# Static proxy (used when TOR_ENABLED=0 and PROXY_URL is set)
PROXY_URL=socks5://127.0.0.1:9050

# FlareSolverr fallback on block
FLARESOLVERR_URL=http://localhost:8191

# VPN rotation command (used by stealth_browser when VPN provider is set)
VPN_ROTATE_COMMAND=

# ─── Crawl ────────────────────────────────────────────────────────────────────
CRAWL_ENABLED=false
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=20
CRAWL_DELAY_MS=750

# ─── Human Simulation ─────────────────────────────────────────────────────────
QA_MOUSE_PATHS_ENABLED=1
QA_MOUSE_PATHS_FILE=test-results/natural-mouse-paths.json

# ─── Red-Team Safety ──────────────────────────────────────────────────────────
REDTEAM_DRY_RUN=1
REDTEAM_ALLOWED_DOMAINS=localhost,127.0.0.1
REDTEAM_MAX_SESSIONS=10
REDTEAM_STOP_ON_BLOCK=1

# ─── Search (if search engine testing is used) ────────────────────────────────
SEARCH_SAFESEARCH_MODE=off
SEARCH_IP_ROTATION_PROVIDER=proxy
SEARCH_PROXY_URLS=
SEARCH_PROXY_CHAIN=0